# Copia este archivo a ".env" y completa los valores.
# (En MVP solo necesitas PORT y ADMIN_KEY)

# ------------------------------------------------------------------
# BÁSICO
# ------------------------------------------------------------------
# Puerto donde corre el backend
PORT=8080

# Clave secreta para las rutas de administración (¡cámbiala por una larga!)
ADMIN_KEY=pon-aqui-una-clave-larga-y-secreta

# ------------------------------------------------------------------
# APP ESPE Player (consulta de estado)
# ------------------------------------------------------------------
# Clave que debe enviar la app en la cabecera x-app-key para consultar estado.
# Si la defines, el endpoint /api/v1/status queda protegido (recomendado).
APP_KEY=
# (Opcional) Secreto para FIRMAR la respuesta de estado (HMAC-SHA256).
# La app puede verificar la firma para asegurar que la respuesta es auténtica.
APP_HMAC_SECRET=

# ------------------------------------------------------------------
# RED / SEGURIDAD
# ------------------------------------------------------------------
# Orígenes permitidos para CORS (coma-separado). '*' permite cualquiera.
# Ej: https://panel.tudominio.com,https://tudominio.com
ALLOWED_ORIGINS=*
# Pon true si el backend corre detrás de un reverse proxy (Nginx/Caddy/Traefik)
# para leer la IP real del cliente desde X-Forwarded-For.
TRUST_PROXY=false
# Tamaño máximo del body en bytes (por defecto 65536 = 64 KB)
MAX_BODY_BYTES=65536

# ------------------------------------------------------------------
# BACKUPS
# ------------------------------------------------------------------
# Días que se conservan los backups en data/backups/
BACKUP_KEEP_DAYS=14

# ------------------------------------------------------------------
# JELLYFIN (el candado real)
# ------------------------------------------------------------------
JELLYFIN_URL=
JELLYFIN_API_KEY=
# (Opcional) timeout y reintentos de las llamadas a Jellyfin
JELLYFIN_TIMEOUT_MS=10000
JELLYFIN_RETRIES=2

# ------------------------------------------------------------------
# NOTIFICACIONES (base; combina proveedores con comas)
#   console | telegram | webhook | whatsapp
# ------------------------------------------------------------------
NOTIFY_PROVIDER=console
# Telegram (avisos para el ADMIN)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Webhook genérico (recibe un POST JSON con cada notificación)
NOTIFY_WEBHOOK_URL=
# WhatsApp Cloud API (mensajes directos al SUSCRIPTOR)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ------------------------------------------------------------------
# BOTS DE PEDIDOS (películas/series con "!pedir <título>")
# ------------------------------------------------------------------
# --- Telegram (long polling, no necesita URL pública) ---
# Usa el mismo TELEGRAM_BOT_TOKEN de arriba. Pon true para activar el bot.
TELEGRAM_BOT_POLLING=false
# --- WhatsApp (webhook de la Cloud API) ---
# Reusa WHATSAPP_TOKEN + WHATSAPP_PHONE_ID de arriba para responder.
# Token que pones en Meta para verificar el webhook (GET).
WHATSAPP_VERIFY_TOKEN=
# App Secret de tu app de Meta (verifica la firma X-Hub-Signature-256 de cada evento).
WHATSAPP_APP_SECRET=
# --- Recomendaciones / catálogo (comandos !recomendaciones y !nuevos) ---
# URL pública del backend, para la página integrada /catalogo (tu catálogo real).
# Ej: https://espe.lat  -> página en https://espe.lat/catalogo
PUBLIC_URL=
# Link que envía !recomendaciones. Si se deja vacío, usa JustWatch Ecuador por defecto.
# Alternativas: https://www.themoviedb.org/?language=es-MX  |  tu propia PUBLIC_URL/catalogo
RECOMMENDATIONS_URL=
# (Opcional) usuario de Jellyfin usado para leer la biblioteca; por defecto el primero.
JELLYFIN_CATALOG_USER=
# (Opcional) minutos de caché del catálogo en milisegundos (por defecto 600000 = 10 min)
CATALOG_TTL_MS=600000

# ------------------------------------------------------------------
# MERCADO PAGO (cobro automático)
# ------------------------------------------------------------------
# Access token de tu cuenta/app de Mercado Pago
MP_ACCESS_TOKEN=
# Clave secreta de la firma del webhook (panel de MP -> Webhooks)
MP_WEBHOOK_SECRET=
