# Copia este archivo a ".env" y completa los valores.
# (En MVP solo necesitas PORT y ADMIN_KEY)

# Puerto donde corre el backend
PORT=8080

# Clave secreta para las rutas de administración (¡cámbiala!)
ADMIN_KEY=pon-aqui-una-clave-larga-y-secreta

# (Opcional) Clave que debe enviar la app ESPE Player para consultar estado
APP_KEY=

# --- FASE PRO: conexión con Jellyfin (el candado real) ---
# URL de tu Jellyfin (interna o pública)
JELLYFIN_URL=
# API key de administrador de Jellyfin (Ajustes -> API Keys)
JELLYFIN_API_KEY=
