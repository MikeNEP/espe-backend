# Copia este archivo a ".env" y completa los valores.
# (En MVP solo necesitas PORT y ADMIN_KEY)

# ------------------------------------------------------------------
# BÁSICO
# ------------------------------------------------------------------
# Puerto donde corre el backend
PORT=8080

# Clave secreta para las rutas de administración (¡cámbiala por una larga!)
ADMIN_KEY=pon-aqui-una-clave-larga-y-secreta

# ------------------------------------------------------------------
# APP ESPE Player (consulta de estado)
# ------------------------------------------------------------------
# Clave que debe enviar la app en la cabecera x-app-key para consultar estado.
# Si la defines, el endpoint /api/v1/status queda protegido (recomendado).
APP_KEY=
# (Opcional) Secreto para FIRMAR la respuesta de estado (HMAC-SHA256).
# La app puede verificar la firma para asegurar que la respuesta es auténtica.
APP_HMAC_SECRET=

# ------------------------------------------------------------------
# RED / SEGURIDAD
# ------------------------------------------------------------------
# Orígenes permitidos para CORS (coma-separado). '*' permite cualquiera.
# Ej: https://panel.tudominio.com,https://tudominio.com
ALLOWED_ORIGINS=*
# Pon true si el backend corre detrás de un reverse proxy (Nginx/Caddy/Traefik)
# para leer la IP real del cliente desde X-Forwarded-For.
TRUST_PROXY=false
# Tamaño máximo del body en bytes (por defecto 65536 = 64 KB)
MAX_BODY_BYTES=65536

# ------------------------------------------------------------------
# BACKUPS
# ------------------------------------------------------------------
# Días que se conservan los backups en data/backups/
BACKUP_KEEP_DAYS=14

# ------------------------------------------------------------------
# JELLYFIN (el candado real)
# ------------------------------------------------------------------
JELLYFIN_URL=
JELLYFIN_API_KEY=
# (Opcional) timeout y reintentos de las llamadas a Jellyfin
JELLYFIN_TIMEOUT_MS=10000
JELLYFIN_RETRIES=2

# ------------------------------------------------------------------
# NOTIFICACIONES (base; combina proveedores con comas)
#   console | telegram | webhook | whatsapp
# ------------------------------------------------------------------
NOTIFY_PROVIDER=console
# Telegram (avisos para el ADMIN)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Webhook genérico (recibe un POST JSON con cada notificación)
NOTIFY_WEBHOOK_URL=
# WhatsApp Cloud API (mensajes directos al SUSCRIPTOR)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ------------------------------------------------------------------
# MERCADO PAGO (cobro automático)
# ------------------------------------------------------------------
# Access token de tu cuenta/app de Mercado Pago
MP_ACCESS_TOKEN=
# Clave secreta de la firma del webhook (panel de MP -> Webhooks)
MP_WEBHOOK_SECRET=
